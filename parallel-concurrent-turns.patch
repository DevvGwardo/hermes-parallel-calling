+    async def _run_concurrent_turn(self, event, source, parent_key: str):
+        """Run a concurrent turn in parallel with an existing running agent.
+        
+        Creates a forked session (via session_key_override) so this turn runs
+        independently without interrupting the main conversation. The original
+        source is preserved so chat_id stays an int (required by Telegram et al.).
+        
+        Each parallel agent receives coordination context in its system prompt
+        listing its siblings, so it can avoid conflicting on shared resources.
+        """
+        import time as _time
+
+        _fork_ts = int(_time.time())
+        _fork_key = f"{parent_key}-c{_fork_ts}"
+
+        # Phase 1: Lock-protected check + registration (fast critical section).
+        # Prevents a TOCTOU race where two concurrent messages both see the
+        # cap as open and register before either can block the other.
+        async with self._get_parallel_lock(parent_key):
+            # Cap: only one parallel agent per session at a time.
+            # If there's already a parallel fork running, queue this message
+            # instead of spawning another agent that would cascade conflicts.
+            if parent_key in self._parallel_agents and self._parallel_agents[parent_key]:
+                logger.debug(
+                    "Parallel cap hit for session %s — queuing message (fork %s blocked)",
+                    parent_key, _fork_key,
+                )
+                adapter = self.adapters.get(source.platform)
+                if adapter:
+                    merge_pending_message_event(adapter._pending_messages, parent_key, event)
+                    try:
+                        _thread_meta = {"thread_id": source.thread_id} if source.thread_id else None
+                        await adapter._send_with_retry(
+                            chat_id=source.chat_id,
+                            content="⏳ One parallel task already running — queued for next slot.",
+                            reply_to=event.message_id,
+                            metadata=_thread_meta,
+                        )
+                    except Exception:
+                        pass
+                return
+
+        # Phase 2: Outside the lock — load history, build context, run agent.
+        # Snapshot the parent session's conversation history so the fork
+        # has context about the conversation it is running alongside.
+        _parent_history: List[Dict[str, Any]] = []
+        try:
+            _parent_entry = self.session_store._entries.get(parent_key)
+            if _parent_entry:
+                _parent_history = self.session_store.load_transcript(_parent_entry.session_id)
+        except Exception as _ph_exc:
+            logger.debug(
+                "Failed to load parent transcript for fork %s: %s",
+                _fork_key, _ph_exc,
+            )
+
+            # Register this parallel agent so siblings know about each other
+            if parent_key not in self._parallel_agents:
+                self._parallel_agents[parent_key] = {}
+            _msg_preview = (event.text or "")[:40]
+            self._parallel_agents[parent_key][_fork_key] = {
+                "start_time": _time.time(),
+                "message_preview": _msg_preview,
+            }
+
+        # Build coordination context with sibling awareness
+        _siblings = [k for k in self._parallel_agents.get(parent_key, {}).keys() if k != _fork_key]
+        _info_lines = ["## Parallel Coordination", ""]
+        _info_lines.append(f"You are parallel agent **{_fork_key}**.")
+        if _siblings:
+            _info_lines.append(f"Siblings currently running: {', '.join(_siblings)}")
+        else:
+            _info_lines.append("No other siblings currently running.")
+        _info_lines.append("")
+        _info_lines.append(
+            "You are running alongside other agents in the same chat. "
+            "Coordinate to avoid conflicts:"
+        )
+        _info_lines.append("- Before modifying files or shared state, check if a sibling has claimed the resource.")
+        _info_lines.append("- If a sibling is doing related work, wait or ask the user for guidance.")
+        _info_lines.append("- Do NOT modify files another agent has claimed or is actively working on.")
+        _info_lines.append("- If you detect a conflict, back off and let the other agent finish.")
+        _info_lines.append("- When you finish, your sibling agents will see your results naturally.")
+        _info_lines.append("- You cannot communicate directly with siblings — coordinate through shared state.")
+        _parallel_context = "\n".join(_info_lines)
+
+        try:
+            # Run the full message pipeline with the original source but a
+            # forked session key.  Session isolation comes from the key, not
+            # from mangling the source's chat_id.
+            _result = await self._handle_message_with_agent(
+                event, source, _fork_key, 0,
+                session_key_override=_fork_key,
+                parallel_context_text=_parallel_context,
+                inherited_context=_parent_history,
+            )
+
+            if _result and isinstance(_result, str):
+                # Deliver the response to the ORIGINAL chat (not the fork)
+                _adapter = self.adapters.get(source.platform)
+                if _adapter:
+                    _preview = (event.text or "")[:60].replace("\n", " ")
+                    _header = f"⚡ [Parallel — \"{_preview}...\"]\n\n"
+                    if _result.startswith("Sorry, I encountered an error"):
+                        await _adapter.send(
+                            source.chat_id,
+                            f"⚠️ Parallel turn failed:\n\n{_result}",
+                        )
+                    else:
+                        await _adapter.send(
+                            source.chat_id,
+                            _header + _result,
+                        )
+        except asyncio.CancelledError:
+            logger.debug("Concurrent turn cancelled for session %s", parent_key)
+        except Exception as exc:
+            logger.exception("Concurrent turn failed for session %s: %s", parent_key, exc)
+            _adapter = self.adapters.get(source.platform)
+            if _adapter:
+                await _adapter.send(
+                    source.chat_id,
+                    f"⚠️ Parallel turn failed: {exc}",
+                )
+        finally:
+            async with self._get_parallel_lock(parent_key):
+            # Clean up: remove this fork from the tracking dict
+                _parent_agents = self._parallel_agents.get(parent_key)
+                if _parent_agents and _fork_key in _parent_agents:
+                    del _parent_agents[_fork_key]
+                    if not _parent_agents:
+                        del self._parallel_agents[parent_key]
+
+    def _get_parallel_lock(self, parent_key: str) -> asyncio.Lock:
+        """Return (and lazily create) a per-session lock for the parallel-agent cap."""
+        lock = self._parallel_locks.get(parent_key)
+        if lock is None:
+            lock = asyncio.Lock()
+            self._parallel_locks[parent_key] = lock
+        return lock

+    def _get_parallel_agents_status(self, session_key: str) -> str:
+        """Return a one-line summary of running parallel agents for this session.
+        
+        Example output:
+          "Parallel agents running: agent-abc123-c1705040000 (18s ago: 'deploy the...'), agent-abc123-c1705040001 (5s ago: 'check logs...')"
+        """
+        import time as _status_time
+        forks = self._parallel_agents.get(session_key, {})
+        if not forks:
+            return ""
+        parts = []
+        now = _status_time.time()
+        for fork_key in sorted(forks.keys()):
+            meta = forks[fork_key]
+            start = meta.get("start_time", now)
+            elapsed = now - start
+            preview = meta.get("message_preview", "")
+            if elapsed < 60:
+                time_str = f"{int(elapsed)}s ago"
+            else:
+                mins = int(elapsed // 60)
+                secs = int(elapsed % 60)
+                time_str = f"{mins}m {secs}s ago" if secs else f"{mins}m ago"
+            parts.append(f"{fork_key} ({time_str}: '{preview}...')")
+        return f"Parallel agents running: {', '.join(parts)}"
+
